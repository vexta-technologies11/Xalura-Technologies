{
  "name": "xalura-tech",
  "version": "0.1.3",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:next": "next build",
    "cf:build": "npm run build",
    "cf:preview": "npm run build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "next lint",
    "agentic:dry-run": "node xalura-agentic/scripts/dry-run.mjs",
    "agentic:cycle-demo": "tsx xalura-agentic/scripts/cycle-demo.ts",
    "agentic:publishing-demo": "tsx xalura-agentic/scripts/publishing-pipeline-demo.ts",
    "agentic:all-departments-demo": "tsx xalura-agentic/scripts/all-departments-demo.ts",
    "agentic:handoff-demo": "tsx xalura-agentic/scripts/handoff-chain-demo.ts",
    "agentic:verify": "tsc --noEmit && npm run lint && npm run agentic:dry-run && npm run agentic:publishing-demo && npm run agentic:all-departments-demo",
    "verify:deploy": "npm run agentic:verify && npm run build",
    "agentic:status": "tsx xalura-agentic/scripts/status.ts",
    "agentic:gemini-ping": "tsx --env-file=.env.local xalura-agentic/scripts/gemini-ping-smoke.ts",
    "agentic:content-workflow-demo": "tsx xalura-agentic/scripts/content-workflow-demo.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/kv": "^3.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.14.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "wrangler": "^4.84.1"
  }
}
