NEXT_PUBLIC_SUPABASE_URL=https://utwbidakrliphhuenvcn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV0d2JpZGFrcmxpcGhodWVudmNuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY2NDQ2MzAsImV4cCI6MjA5MjIyMDYzMH0.p-rzKj2CBshMAfN9WbamYnIPP_XxzTJps0rDctA4u7M
# Required for POST /api/agent-update (Bearer key validation + insert). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Recommended for “all agents welcome”: one long random string (e.g. openssl rand -hex 32).
# You create this value — it is NOT shown in the admin UI. Paste the same value into Vercel + GearMedic.
# Send as: Authorization: Bearer <value>   OR header: X-Xalura-Ingest-Token: <value>
# JSON agent_id can be any label (Kimmy, Mochi, …). Approve in Admin → AI Dashboard to register in Supabase.
# Same value can use any of these env names (pick one):
AGENT_INGEST_SECRET=
# XALURA_INGEST_TOKEN=
# XALURA_AGENT_BEARER=
#
# Sanity check after deploy: GET https://www.xaluratech.com/api/ingest-health
#
# If ALL ingest env names are empty, only per-employee xal_ keys from Admin → AI Dashboard → Settings work.
#
# Bootstrap: until you approve OR decline at least one agent update in Admin → AI Dashboard, POST /api/agent-update
# accepts JSON or form without Bearer (defaults: agent_id → guest, activity_text → (no activity_text)).
# After that review, Bearer (shared secret or xal_) is required unless AGENT_UPDATE_OPEN_INGEST=true.

# Set to true ONLY to keep unauthenticated POST after the first review (public spam risk). Default is false.
# AGENT_UPDATE_OPEN_INGEST=false

# TEST / GearMedic: set true so wrong Bearer, unknown xal_, inactive key, or bad agent_id still inserts a pending row.
# Remove or false once tokens match — public abuse risk while enabled.
# AGENT_UPDATE_ACCEPT_ANY=false

# Used only as documentation — create the admin user in Supabase Auth with these credentials.
ADMIN_EMAIL=
ADMIN_PASSWORD=
